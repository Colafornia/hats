{
  "name": "hats",
  "version": "0.1.0",
  "description": "Per-terminal / per-process config isolator for Claude Code, Codex, and any CLI — switch hats without polluting your shell.",
  "type": "module",
  "bin": {
    "hats": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "shell-quote": "^1.8.1",
    "smol-toml": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/shell-quote": "^1.7.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}